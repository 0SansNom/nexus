# NEXUS Environment Configuration

# Server
SERVER_ADDR=127.0.0.1:3000

# Database
DATABASE_PATH=./data/nexus.db
DATABASE_KEY=your-encryption-key-here

# Redis
REDIS_URL=redis://localhost:6379

# LLM Configuration
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5-20250929
LLM_API_KEY=your-anthropic-api-key

# Email Configuration (for email agent)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# Google Calendar (for calendar agent)
GOOGLE_CREDENTIALS_PATH=./credentials/google-calendar.json
GOOGLE_CALENDAR_ID=primary

# ChromaDB (for memory agent)
CHROMA_PERSIST_DIR=./data/chroma

# Coordinator URL (for agents to connect)
COORDINATOR_URL=http://localhost:3000

# Security
JWT_SECRET=your-jwt-secret-here
